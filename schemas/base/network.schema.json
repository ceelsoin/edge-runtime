{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://edge-runtime.dev/schemas/base/network.schema.json",
  "title": "Edge Runtime Network Target Types",
  "$defs": {
    "hostname": {
      "type": "string",
      "pattern": "^(?=.{1,253}$)(?!-)(?:[A-Za-z0-9](?:[A-Za-z0-9-]{0,61}[A-Za-z0-9])?)(?:\\.(?:[A-Za-z0-9](?:[A-Za-z0-9-]{0,61}[A-Za-z0-9])?))*$"
    },
    "ipv4": {
      "type": "string",
      "pattern": "^(?:25[0-5]|2[0-4]\\d|1\\d\\d|[1-9]?\\d)(?:\\.(?:25[0-5]|2[0-4]\\d|1\\d\\d|[1-9]?\\d)){3}$"
    },
    "ipv4Cidr": {
      "type": "string",
      "pattern": "^(?:25[0-5]|2[0-4]\\d|1\\d\\d|[1-9]?\\d)(?:\\.(?:25[0-5]|2[0-4]\\d|1\\d\\d|[1-9]?\\d)){3}\\/(?:[0-9]|[1-2][0-9]|3[0-2])$"
    },
    "ipv6Bracketed": {
      "type": "string",
      "pattern": "^\\[[0-9A-Fa-f:]+\\]$"
    },
    "ipv6CidrBracketed": {
      "type": "string",
      "pattern": "^\\[[0-9A-Fa-f:]+\\]\\/(?:[0-9]|[1-9][0-9]|1[0-1][0-9]|12[0-8])$"
    },
    "target": {
      "anyOf": [
        { "$ref": "#/$defs/hostname" },
        { "type": "string", "pattern": "^(?=.{1,253}$)(?!-)(?:[A-Za-z0-9](?:[A-Za-z0-9-]{0,61}[A-Za-z0-9])?)(?:\\.(?:[A-Za-z0-9](?:[A-Za-z0-9-]{0,61}[A-Za-z0-9])?))*:[1-9][0-9]{0,4}$" },
        { "$ref": "#/$defs/ipv4" },
        { "type": "string", "pattern": "^(?:25[0-5]|2[0-4]\\d|1\\d\\d|[1-9]?\\d)(?:\\.(?:25[0-5]|2[0-4]\\d|1\\d\\d|[1-9]?\\d)){3}:[1-9][0-9]{0,4}$" },
        { "$ref": "#/$defs/ipv4Cidr" },
        { "type": "string", "pattern": "^(?:25[0-5]|2[0-4]\\d|1\\d\\d|[1-9]?\\d)(?:\\.(?:25[0-5]|2[0-4]\\d|1\\d\\d|[1-9]?\\d)){3}\\/(?:[0-9]|[1-2][0-9]|3[0-2]):[1-9][0-9]{0,4}$" },
        { "$ref": "#/$defs/ipv6Bracketed" },
        { "type": "string", "pattern": "^\\[[0-9A-Fa-f:]+\\]:[1-9][0-9]{0,4}$" },
        { "$ref": "#/$defs/ipv6CidrBracketed" },
        { "type": "string", "pattern": "^\\[[0-9A-Fa-f:]+\\]\\/(?:[0-9]|[1-9][0-9]|1[0-1][0-9]|12[0-8]):[1-9][0-9]{0,4}$" }
      ]
    }
  }
}
