{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://edge-runtime.dev/schemas/base/common.schema.json",
  "title": "Edge Runtime Common Types",
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "port": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535
    },
    "logLevel": {
      "type": "string",
      "enum": ["trace", "debug", "info", "warn", "error"]
    },
    "envName": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]{0,127}$"
    },
    "functionName": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{0,62}$"
    }
  }
}
